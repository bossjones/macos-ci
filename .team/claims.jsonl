// --- 13-build-secrets.md: build-time secret injection -----------------------
// The masking trio is a unit. "The secret didn't print" is only meaningful next to
// a control proving `packer inspect` prints plain literals at all.
{"id": "packer-is-installed", "kind": "cli-help", "file": "specs/macos-ci/13-build-secrets.md", "argv": ["packer", "version"], "expect": "Packer v1.", "claim": "packer is installed on the build host; retires the 'missing packer' prose in specs/macos-ci.md"}
{"id": "packer-sensitive-masks-value", "kind": "cli-help", "file": "specs/macos-ci/13-build-secrets.md", "argv": ["packer", "inspect", "tests/fixtures/packer-sensitive"], "expect": "<sensitive>", "claim": "a variable marked sensitive=true prints as <sensitive>"}
{"id": "CONTROL-packer-inspect-prints-plain-literals", "kind": "cli-help", "file": "specs/macos-ci/13-build-secrets.md", "argv": ["packer", "inspect", "tests/fixtures/packer-sensitive"], "expect": "plain_FIXTURE_CONTROL", "claim": "CONTROL for packer-sensitive-hides-secret: packer inspect DOES print non-sensitive literals. If this fails, 'the secret was absent' proves nothing — inspect printed nothing."}
{"id": "packer-sensitive-hides-secret", "kind": "cli-help", "must_fail": true, "file": "specs/macos-ci/13-build-secrets.md", "argv": ["packer", "inspect", "tests/fixtures/packer-sensitive"], "expect": "ghp_FIXTURE_SENTINEL", "claim": "the sensitive value never reaches packer's output. Paired with CONTROL-packer-inspect-prints-plain-literals."}
{"id": "packer-sensitive-hides-secret-under-debug-log", "kind": "cli-help", "must_fail": true, "file": "specs/macos-ci/13-build-secrets.md", "argv": ["packer", "inspect", "tests/fixtures/packer-sensitive"], "env": {"PACKER_LOG": "1"}, "expect": "ghp_FIXTURE_SENTINEL", "claim": "masking survives PACKER_LOG=1; the debug log is not a bypass. Paired with CONTROL-packer-debug-log-prints-plain-literals."}
{"id": "CONTROL-packer-debug-log-prints-plain-literals", "kind": "cli-help", "file": "specs/macos-ci/13-build-secrets.md", "argv": ["packer", "inspect", "tests/fixtures/packer-sensitive"], "env": {"PACKER_LOG": "1"}, "expect": "plain_FIXTURE_CONTROL", "claim": "CONTROL: under PACKER_LOG=1 packer still emits non-sensitive literals, so the must_fail claim above is not vacuous"}
